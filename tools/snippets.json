{
  "Примечание": {
    "prefix": "note",
    "body": [
      "!!! note \"Примечание\"",
      "    $1"
    ],
    "description": "Блок примечания"
  },
  "Предупреждение": {
    "prefix": "warn",
    "body": [
      "!!! warning \"Внимание\"",
      "    $1"
    ],
    "description": "Блок предупреждения"
  },
  "Навигация": {
    "prefix": "nav",
    "body": "Откройте **«$1»** → **«$2»**.",
    "description": "Путь навигации со стрелкой"
  },
  "Поле формы": {
    "prefix": "field",
    "body": "- **$1**: $2.",
    "description": "Описание поля формы"
  },
  "Скриншот формы": {
    "prefix": "form",
    "body": [
      "Пример заполненной формы:",
      "",
      "![$1](../media/$2.png)",
      "",
      "Чтобы заполнить форму по сохраненному шаблону, нажмите кнопку ![](../media/image26.png) и выберите **Заполнить по шаблону**.",
      "",
      "Или введите данные вручную:",
      "",
      "- **$3**: $4."
    ],
    "description": "Типовой блок: скриншот + поля формы"
  },
  "Якорь заголовка": {
    "prefix": "anchor",
    "body": "## $1 { #$2 }",
    "description": "Заголовок H2 с якорем для ссылки"
  },
  "Ссылка с якорем": {
    "prefix": "alink",
    "body": "[$1]($2#$3)",
    "description": "Ссылка на раздел другой страницы"
  },
  "Сохранить в справочнике": {
    "prefix": "save",
    "body": "Нажмите **Сохранить**. $1 будет сохранен и доступен при создании платежных документов.",
    "description": "Фраза подтверждения сохранения в справочнике"
  }
}
